-- 1. CRITICAL FIX: Explicitly add the lua folder to the runtime path
-- This ensures Neovim finds 'config.options', 'config.keymaps', etc.
vim.opt.runtimepath:prepend(vim.fn.stdpath("config") .. "/lua")

-- 2. Bootstrap Lazy.nvim (Plugin Manager)
local lazypath = vim.fn.stdpath("data") .. "/lazy/lazy.nvim"
if not vim.loop.fs_stat(lazypath) then
  vim.fn.system({
    "git",
    "clone",
    "--filter=blob:none",
    "https://github.com/folke/lazy.nvim.git",
    "--branch=stable",
    lazypath,
  })
end
vim.opt.rtp:prepend(lazypath)

-- 3. Load your modules
-- Now these will work because we added the path in step 1
require("config.options")
require("config.keymaps")
require("config.lazy")

