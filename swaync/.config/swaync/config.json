{
  "$schema": "/etc/xdg/swaync/configSchema.json",
  "positionX": "right",
  "positionY": "top",
  "cssPriority": "user",
  "control-center-width": 380,
  "control-center-height": 660,
  "control-center-margin-top": 2,
  "control-center-margin-bottom": 2,
  "control-center-margin-right": 1,
  "control-center-margin-left": 0,
  "notification-window-width": 400,
  "notification-icon-size": 48,
  "notification-body-image-height": 160,
  "notification-body-image-width": 200,
  "timeout": 4,
  "timeout-low": 2,
  "timeout-critical": 6,
  "fit-to-screen": false,
  "keyboard-shortcuts": true,
  "image-visibility": "when-available",
  "transition-time": 200,
  "hide-on-clear": false,
  "hide-on-action": false,
  "script-fail-notify": true,
  "widgets": [
    "buttons-grid",
    "mpris",
    "dnd",
    "notifications"
  ],
  "widget-config": {
    "title": {
      "text": "Notifications",
      "clear-all-button": true,
      "button-text": " 󰎟 "
    },
    "dnd": {
      "text": "Do not disturb"
    },
    "label": {
      "max-lines": 1,
      "text": " "
    },
    "mpris": {
      "image-size": 96,
      "image-radius": 12
    },
    "buttons-grid": {
      "actions": [
        {
          "label": "󰂭",
          "command": "swaync-client -d",
          "type": "toggle"
        },
        {
          "label": "󰖙",
          "command": "pkill wlsunset || wlsunset -t 4000 -T 6500",
          "type": "toggle"
        },
        {
          "label": "󰅌",
          "command": "cliphist list | wofi --dmenu | cliphist decode | wl-copy"
        },
        {
          "label": "󰅶",
          "command": "pkill swayidle || swayidle -w timeout 600 'swaylock -f' &",
          "type": "toggle"
        }
      ]
    }
  }
}


